# Used by docker-compose.yml. Copy to `.env` and fill in real values before
# running `docker compose up`.

# --- Postgres ---
POSTGRES_USER=storyforge
POSTGRES_PASSWORD=change-me
POSTGRES_DB=storyforge
# Host port to expose Postgres on (omit/remove the "ports:" mapping in
# docker-compose.yml if you don't want it reachable from the host at all)
POSTGRES_PORT=5432

# --- API ---
# Must be a long random string in any real deployment.
JWT_SECRET=change-me
API_PORT=4000

# --- Web ---
WEB_PORT=8080
