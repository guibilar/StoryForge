// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CampaignRole {
  OWNER
  STORYTELLER
  CO_STORYTELLER
  PLAYER
  OBSERVER
}

enum Visibility {
  PUBLIC
  STORYTELLER
  PRIVATE
}

enum EntityCategory {
  CHARACTER
  LOCATION
  ORGANIZATION
  ITEM
  OTHER
}

enum NoteVisibility {
  SHARED
  PRIVATE
  TARGETED
}

enum RelationshipVisibility {
  PUBLIC
  STORYTELLER
  TARGETED
}

model Campaign {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  entities        Entity[]
  members         CampaignMember[]
  tags            Tag[]
  relationships   Relationship[]
  notes           Note[]
  sessions        Session[]
  events          Event[]
  workspaceStates WorkspaceState[]
  markers         Marker[]
  territories     Territory[]
  mapImage        MapImage?
}

model Entity {
  id          String  @id @default(uuid())
  campaignId  String
  ownerUserId String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // The Player Character's owning campaign member. Nullable, and cleared
  // (not cascaded) when the User is removed — a departed player's PC stays
  // in the campaign, just unowned. Resolved via (campaignId, ownerUserId)
  // at the application layer, not this User relation directly, since a
  // CampaignMember has no synthetic id of its own (see CampaignMember
  // model's @@unique([campaignId, userId])).
  owner    User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  type              String
  category          EntityCategory
  isPlayerCharacter Boolean        @default(false)
  name              String
  description       String?
  icon              String?
  image             String?
  // Overrides the type-derived colour markers/territories otherwise fall
  // back to on the map — see Entity.Color in packages/domain.
  color             String?

  visibility Visibility @default(PUBLIC)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tags EntityTag[]

  relationshipsAsSource Relationship[] @relation("RelationshipSource")
  relationshipsAsTarget Relationship[] @relation("RelationshipTarget")

  backlinks NoteLink[] @relation("NoteLinkTargetEntity")

  eventParticipations EventParticipant[]
  markers             Marker[]
  territories         Territory[]

  // Actual uniqueness is a partial index excluding soft-deleted rows
  // (see migration 20260715120000_partial_unique_soft_delete) — Prisma's
  // declarative @@unique can't express a WHERE deletedAt IS NULL clause.
  @@index([campaignId, name])
  @@index([campaignId])
  @@index([ownerUserId])
}

model Session {
  id            String @id @default(uuid())
  campaignId    String
  sessionNumber Int

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  date    DateTime
  summary String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    Event[]
  attendees SessionAttendee[]

  @@unique([campaignId, sessionNumber])
  @@index([campaignId])
}

model SessionAttendee {
  id        String @id @default(uuid())
  sessionId String
  userId    String

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model Event {
  id         String  @id @default(uuid())
  campaignId String
  sessionId  String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session  Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  title       String
  description String?
  // Free-text in-fiction ordering ("Day 14, after the masquerade"), not a
  // real-world date — Timeline events have no calendar dates by design
  // (KAN-49), distinct from Session.date. Sorted lexicographically.
  occurredAt  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants EventParticipant[]

  @@index([campaignId])
  @@index([sessionId])
}

model EventParticipant {
  id       String @id @default(uuid())
  eventId  String
  entityId String

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  role String?

  createdAt DateTime @default(now())

  @@unique([eventId, entityId])
  @@index([eventId])
  @@index([entityId])
}

model Tag {
  id         String @id @default(uuid())
  campaignId String
  name       String

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  entities EntityTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, name])
  @@index([campaignId])
}

model EntityTag {
  id       String @id @default(uuid())
  entityId String
  tagId    String

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([entityId, tagId])
  @@index([entityId])
  @@index([tagId])
}

model Relationship {
  id             String @id @default(uuid())
  campaignId     String
  sourceEntityId String
  targetEntityId String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  source   Entity   @relation("RelationshipSource", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  target   Entity   @relation("RelationshipTarget", fields: [targetEntityId], references: [id], onDelete: Cascade)

  type        String
  description String?

  visibility RelationshipVisibility @default(PUBLIC)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  recipients RelationshipRecipient[]

  // Actual uniqueness is a partial index excluding soft-deleted rows
  // (see migration 20260715120000_partial_unique_soft_delete) — Prisma's
  // declarative @@unique can't express a WHERE deletedAt IS NULL clause.
  @@index([campaignId, sourceEntityId, targetEntityId, type])
  @@index([campaignId])
  @@index([sourceEntityId])
  @@index([targetEntityId])
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignMemberships      CampaignMember[]
  notes                    Note[]
  sessionAttendances       SessionAttendee[]
  noteRecipiencies         NoteRecipient[]
  relationshipRecipiencies RelationshipRecipient[]
  workspaceStates          WorkspaceState[]
  ownedEntities            Entity[]
}

model Note {
  id           String  @id @default(uuid())
  campaignId   String
  authorId     String
  parentNoteId String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Note?    @relation("NoteParent", fields: [parentNoteId], references: [id], onDelete: Cascade)

  title   String
  content String @db.Text

  visibility NoteVisibility @default(SHARED)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  attachments Attachment[]
  children    Note[]          @relation("NoteParent")
  recipients  NoteRecipient[]

  linksOut NoteLink[] @relation("NoteLinkSource")
  linksIn  NoteLink[] @relation("NoteLinkTargetNote")

  @@index([campaignId])
  @@index([parentNoteId])
}

model NoteRecipient {
  id     String @id @default(uuid())
  noteId String
  userId String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([noteId, userId])
  @@index([noteId])
  @@index([userId])
}

model NoteLink {
  id     String @id @default(uuid())
  noteId String

  note Note @relation("NoteLinkSource", fields: [noteId], references: [id], onDelete: Cascade)

  targetEntityId String?
  targetEntity   Entity? @relation("NoteLinkTargetEntity", fields: [targetEntityId], references: [id], onDelete: Cascade)

  targetNoteId String?
  targetNote   Note?   @relation("NoteLinkTargetNote", fields: [targetNoteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([noteId])
  @@index([targetEntityId])
  @@index([targetNoteId])
}

model RelationshipRecipient {
  id             String @id @default(uuid())
  relationshipId String
  userId         String

  relationship Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([relationshipId, userId])
  @@index([relationshipId])
  @@index([userId])
}

model Attachment {
  id     String @id @default(uuid())
  noteId String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  url       String
  fileName  String
  mimeType  String
  sizeBytes Int

  createdAt DateTime @default(now())

  @@index([noteId])
}

model CampaignMember {
  id         String       @id @default(uuid())
  campaignId String
  userId     String
  role       CampaignRole

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, userId])
  // A campaign may have at most one OWNER, enforced by a partial unique
  // index (see migration 20260716120000_campaign_member_single_owner) —
  // Prisma's declarative @@unique can't express a WHERE role = 'OWNER'
  // clause.
  @@index([campaignId])
}

// Optional server-persisted upgrade path for what KAN-100/101 keep in
// localStorage (recently-opened entities, saved window layout) — see
// KAN-103. One row per (user, campaign): the client always overwrites the
// whole thing, there's no history/audit need, so no soft-delete here.
model WorkspaceState {
  id         String @id @default(uuid())
  userId     String
  campaignId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  layout          Json
  recentEntityIds Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, campaignId])
  @@index([campaignId])
}

// A single point on a campaign's map (KAN-51), rendered as a Leaflet marker
// on top of KAN-50's base map canvas.
model Marker {
  id         String  @id @default(uuid())
  campaignId String
  entityId   String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // SetNull, unlike the Cascade on campaign: deleting the entity a marker
  // points at must clear the link, not erase the annotation. Someone tidying
  // up world data shouldn't silently remove pins from the map.
  entity   Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)

  name        String
  lat         Float
  lng         Float
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([entityId])
}

// A shaped area on a campaign's map (KAN-51) — territories, regions, and
// districts are all this one model, distinguished only by the free-string
// `type` column, matching the Entity.type pattern rather than separate
// Region/District tables. `geometry` is a GeoJSON object (validated at the
// domain layer, not here).
model Territory {
  id         String  @id @default(uuid())
  campaignId String
  entityId   String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // SetNull for the same reason as Marker.entity.
  entity   Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)

  name        String
  type        String
  geometry    Json
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([entityId])
}

// A campaign's custom map background (KAN-52) — one per campaign, rendered
// as a Leaflet CRS.Simple ImageOverlay instead of the tile layer when
// present. width/height are the source image's pixel dimensions, used to
// derive the overlay bounds without apps/web needing to load the image
// first to measure it.
model MapImage {
  id         String @id @default(uuid())
  campaignId String @unique

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  url       String
  fileName  String
  mimeType  String
  sizeBytes Int
  width     Int
  height    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
