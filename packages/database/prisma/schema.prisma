// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CampaignRole {
  OWNER
  STORYTELLER
  PLAYER
}

enum Visibility {
  PUBLIC
  STORYTELLER
  PRIVATE
}

model Campaign {
  id          String  @id @default(uuid())
  name        String
  description String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  entities      Entity[]
  members       CampaignMember[]
  tags          Tag[]
  relationships Relationship[]
  notes         Note[]
}

model Entity {
  id         String @id @default(uuid())
  campaignId String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  type        String
  name        String
  description String?
  icon        String?
  image       String?

  visibility Visibility @default(PUBLIC)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tags EntityTag[]

  relationshipsAsSource Relationship[] @relation("RelationshipSource")
  relationshipsAsTarget Relationship[] @relation("RelationshipTarget")

  @@unique([campaignId, name])
  @@index([campaignId])
}

model Tag {
  id         String @id @default(uuid())
  campaignId String
  name       String

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  entities EntityTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, name])
  @@index([campaignId])
}

model EntityTag {
  id       String @id @default(uuid())
  entityId String
  tagId    String

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([entityId, tagId])
  @@index([entityId])
  @@index([tagId])
}

model Relationship {
  id             String @id @default(uuid())
  campaignId     String
  sourceEntityId String
  targetEntityId String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  source   Entity   @relation("RelationshipSource", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  target   Entity   @relation("RelationshipTarget", fields: [targetEntityId], references: [id], onDelete: Cascade)

  type        String
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([campaignId, sourceEntityId, targetEntityId, type])
  @@index([campaignId])
  @@index([sourceEntityId])
  @@index([targetEntityId])
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignMemberships CampaignMember[]
  notes               Note[]
}

model Note {
  id         String @id @default(uuid())
  campaignId String
  authorId   String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  title   String
  content String @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([campaignId])
}

model CampaignMember {
  id         String       @id @default(uuid())
  campaignId String
  userId     String
  role       CampaignRole

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, userId])
  @@index([campaignId])
}
